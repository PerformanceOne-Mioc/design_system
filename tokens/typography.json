{
  "$schema": "https://design-tokens.org/schema.json",
  "font": {
    "display": {
      "$value": "'Barlow Semi Condensed', sans-serif",
      "$type": "fontFamily",
      "$description": "Condensed industrial grotesque. Headings, KPI values, nav labels, button labels, eyebrows."
    },
    "body": {
      "$value": "'Atkinson Hyperlegible', sans-serif",
      "$type": "fontFamily",
      "$description": "Maximum legibility by design. Body copy, form labels, table cells, descriptions."
    }
  },
  "fontSize": {
    "xs":   { "$value": "0.75rem",   "$type": "dimension", "$description": "Tags, metadata, captions" },
    "sm":   { "$value": "0.875rem",  "$type": "dimension", "$description": "Form labels, secondary nav, small badges" },
    "base": { "$value": "1rem",      "$type": "dimension", "$description": "Body text, table cells, inputs" },
    "lg":   { "$value": "1.125rem",  "$type": "dimension", "$description": "Card subtitles, section intros" },
    "xl":   { "$value": "1.375rem",  "$type": "dimension", "$description": "Panel headings, sub-section H3" },
    "2xl":  { "$value": "1.75rem",   "$type": "dimension", "$description": "Section H2, large KPI deltas" },
    "3xl":  { "$value": "2.25rem",   "$type": "dimension", "$description": "Page H1 in app context" },
    "4xl":  { "$value": "3rem",      "$type": "dimension", "$description": "Marketing heading, large KPI values" },
    "5xl":  { "$value": "4rem",      "$type": "dimension", "$description": "Hero display (fluid via clamp in marketing)" }
  },
  "fontWeight": {
    "light":   { "$value": "300", "$type": "fontWeight", "$description": "Italic counterpoint in display" },
    "regular": { "$value": "400", "$type": "fontWeight", "$description": "Body default" },
    "medium":  { "$value": "500", "$type": "fontWeight", "$description": "Button labels, emphasis" },
    "semibold":{ "$value": "600", "$type": "fontWeight", "$description": "Section headings" },
    "bold":    { "$value": "700", "$type": "fontWeight", "$description": "KPI values, display headlines" }
  },
  "lineHeight": {
    "display": { "$value": "0.98", "$description": "Large display (≥2.5rem)" },
    "heading":  { "$value": "1.1",  "$description": "Section headings" },
    "ui":       { "$value": "1.4",  "$description": "UI elements, buttons, labels" },
    "body":     { "$value": "1.6",  "$description": "Body text" },
    "relaxed":  { "$value": "1.65", "$description": "Long-form description text" }
  },
  "letterSpacing": {
    "tight":    { "$value": "-0.02em",  "$description": "Large display headlines" },
    "normal":   { "$value": "0",        "$description": "Body default" },
    "wide":     { "$value": "0.03em",   "$description": "Nav links" },
    "wider":    { "$value": "0.04em",   "$description": "Button labels" },
    "widest":   { "$value": "0.08em",   "$description": "Small uppercase category labels" },
    "tracking": { "$value": "0.12em",   "$description": "Eyebrow/eyebrow-style labels" }
  },
  "measure": {
    "body": { "$value": "65ch", "$description": "Max line length for body text" },
    "narrow": { "$value": "42ch", "$description": "Max line length for intro/subheadline text" }
  }
}
