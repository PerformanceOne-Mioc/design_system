{
  "$schema": "https://design-tokens.org/schema.json",
  "$description": "4pt base spacing scale. Use --space-{n} in CSS. Never use calc() percentage hacks.",
  "spacing": {
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension" },
    "8":  { "$value": "32px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension" }
  },
  "radius": {
    "sm":   { "$value": "10px",   "$type": "dimension", "$description": "Compact elements — tags inside cards, icon containers" },
    "md":   { "$value": "16px",   "$type": "dimension", "$description": "Inputs, small cards" },
    "lg":   { "$value": "24px",   "$type": "dimension", "$description": "Standard cards, panels" },
    "xl":   { "$value": "32px",   "$type": "dimension", "$description": "Hero cards, feature panels" },
    "2xl":  { "$value": "48px",   "$type": "dimension", "$description": "Dark glass section container" },
    "pill": { "$value": "9999px", "$type": "dimension", "$description": "Buttons, badges, tags, nav bar" }
  },
  "container": {
    "maxWidth": { "$value": "1200px", "$description": "Page content max-width" },
    "paddingX":  { "$value": "32px",   "$description": "Container horizontal padding (16px on mobile)" }
  }
}
